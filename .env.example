# ─────────────────────────────────────────────────────────────────────────
# Copiez ce fichier vers .env  ->  cp .env.example .env
# .env est git-ignoré : les comptes de test ne sont JAMAIS commités.
# En CI, ces valeurs proviennent des secrets GitHub.
# ─────────────────────────────────────────────────────────────────────────

# Compte de démo (côté API + utilisé par la suite de tests)
TASKLY_DEMO_EMAIL=demo@taskly.app
TASKLY_DEMO_PASSWORD=password123

# Secret protégeant les endpoints de test (reset / teardown).
# Mettez une valeur longue et aléatoire en vrai.
TEST_SUPPORT_SECRET=local-test-secret-change-me

# API
API_PORT=3001

# URLs consommées par le front (Vite) et par la suite Playwright
VITE_API_URL=http://localhost:3001
BASE_URL=

# Hint affiché sur l'écran de login en démo (laisser vide pour masquer).
# Pratique en démo, à NE PAS renseigner sur un vrai environnement.
VITE_DEMO_EMAIL=demo@taskly.app
VITE_DEMO_PASSWORD=password123
