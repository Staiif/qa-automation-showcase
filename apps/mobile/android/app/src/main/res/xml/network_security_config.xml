<?xml version="1.0" encoding="utf-8"?>
<!--
  Detox talks to its host test server over a cleartext WebSocket. Release builds
  block cleartext by default, so we permit it ONLY for the loopback / emulator
  host — just enough to run E2E tests against a release (bundled) build.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
    </domain-config>
</network-security-config>
